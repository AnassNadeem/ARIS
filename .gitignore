# Parquet & pickles outside the data dir
*.parquet
*.pkl
*.pickle

# Secrets & env
.env
.env.*
*.key

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code local state (personal, not portable)
.claude/

# Logs
*.log
wandb/
mlruns/
